operator    = >
unit        = count
window      = 3
enabled     = true
description = InnoDB row-level lock waits (MySQL)

[metric.db.mysql.deadlocks_per_min]
critical    = 20
warning     = 5
info        = 1
operator    = >
unit        = count/min
window      = 2
enabled     = true
description = InnoDB deadlocks (MySQL)

[metric.db.mysql.replication_lag_s]
critical    = 120
warning     = 30
info        = 10
operator    = >
unit        = seconds
window      = 3
enabled     = true
description = Replica lag (MySQL SHOW SLAVE STATUS)

