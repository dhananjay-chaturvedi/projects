# ================================================================
# Monitor Thresholds Configuration
# ================================================================
# Each section defines threshold rules for one metric with three
# severity levels: INFO, WARNING, and CRITICAL.
#
# Fields:
#   critical    - value that triggers a CRITICAL alert  (red)
#   warning     - value that triggers a WARNING alert   (yellow)
#   info        - value that triggers an INFO alert     (blue)
#   operator    - '>' (alert when value exceeds) or '<' (alert when below)
#   unit        - display unit shown in alert messages
#   window      - number of consecutive breaches before firing (sustained_breach)
#   enabled     - true/false to toggle the rule without deleting it
#   description - human-readable label used in alert messages
#
# Severity evaluation order: CRITICAL is checked first, then WARNING, then INFO.
# Only the highest breached level fires per sample.
#
# For operator '>':  value > critical → CRITICAL  |  > warning → WARNING  |  > info → INFO
# For operator '<':  value < critical → CRITICAL  |  < warning → WARNING  |  < info → INFO
#
# Section naming:
#   [metric.<source>.<rule_id>]                         os / generic db (3 parts)
#   [metric.db.<engine>.<rule_id>]                      per-engine db override (4 parts)
#   [metric.<source>.<api>.<...path...>.<rule_id>]     cloud (4+ parts)
#
# DB lookups try the engine-specific section first (mysql, oracle, postgresql,
# sqlite — MariaDB aliases to mysql) and fall back to the generic [metric.db.*]
# default when no override exists.
#
# Cloud sections require:  metric_name = <exact API metric string>
# rule_id is the stable key used by collectors; metric_name is what the
# cloud API is called with (they may differ, e.g. GCP cpu_utilization vs
# cloudsql.googleapis.com/database/cpu/utilization).
#
# Sources / APIs:
#   os    - host metrics via SSH only (no api/path)
#   db    - database metrics via SQL (generic + optional per-engine path)
#   aws   - cloudwatch (AWS/RDS) | pi (Performance Insights)
#   azure - azuremonitor (per Microsoft.<RP>/<resourceType> path)
#   gcp   - cloudmonitoring (cloudsql.database.* path)
# ================================================================


# ----------------------------------------------------------------
# OS  —  host-level metrics
# ----------------------------------------------------------------

[metric.os.cpu_utilization]
critical    = 90
warning     = 80
info        = 70
operator    = >
unit        = percent
window      = 3
enabled     = true
description = Host CPU utilization

[metric.os.free_memory_mb]
critical    = 256
warning     = 512
info        = 1024
operator    = <
unit        = MB
window      = 3
enabled     = true
description = Host free memory

[metric.os.free_disk_gb]
critical    = 2
warning     = 5
info        = 10
operator    = <
unit        = GB
window      = 3
enabled     = true
description = Host free disk space

[metric.os.disk_io_util_percent]
critical    = 95
warning     = 85
info        = 70
operator    = >
unit        = percent
window      = 3
enabled     = true
description = Disk I/O utilization

[metric.os.load_avg_1m]
critical    = 28.0 #8
warning     = 14.0 #4
info        = 12.0 #2
operator    = >
unit        = ratio
window      = 3
enabled     = true
description = 1-minute load average

[metric.os.swap_used_mb]
critical    = 2048
warning     = 1024
info        = 512
operator    = >
unit        = MB
window      = 3
enabled     = true
description = Swap space used

[metric.os.network_errors_per_sec]
critical    = 50
warning     = 10
info        = 5
operator    = >
unit        = errors/sec
window      = 3
enabled     = true
description = Network interface errors per second

[metric.os.memory_utilization]
critical    = 95
warning     = 90
info        = 80
operator    = >
unit        = percent
window      = 3
enabled     = true
description = Host memory utilization percent

[metric.os.disk_utilization]
critical    = 95
warning     = 85
info        = 70
operator    = >
unit        = percent
window      = 3
enabled     = true
description = Host disk utilization percent

[metric.os.net_errors]
critical    = 50
warning     = 10
info        = 5
operator    = >
unit        = count
window      = 3
enabled     = true
description = Network interface errors (psutil; cumulative total)


# ----------------------------------------------------------------
# DB  —  generic database metrics (engine-agnostic defaults)
# Per-engine overrides: [metric.db.mysql.*], [metric.db.oracle.*], etc.
# ----------------------------------------------------------------

[metric.db.active_connections]
critical    = 800
warning     = 400
info        = 200
operator    = >
unit        = count
window      = 3
enabled     = true
description = Active database connections

[metric.db.connection_pool_wait_ms]
critical    = 2000
warning     = 500
info        = 200
operator    = >
unit        = ms
window      = 3
enabled     = true
