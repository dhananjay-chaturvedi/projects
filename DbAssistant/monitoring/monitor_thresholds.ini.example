# ----------------------------------------------------------------
# GCP  —  Cloud Monitoring (cloudsql.googleapis.com metric types)
# ----------------------------------------------------------------
# Path: <api>.<service>.<resource>.<rule_id>
# Resource type derived as "<service>_<resource>" -> "cloudsql_database".
# metric_name carries the verbatim GCP metric type URI.

[metric.gcp.cloudmonitoring.cloudsql.database.cpu_utilization]
metric_name = cloudsql.googleapis.com/database/cpu/utilization
