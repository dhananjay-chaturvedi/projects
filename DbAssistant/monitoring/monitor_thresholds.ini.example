# ================================================================
# DB per-engine override sets
# ================================================================
# One section per metric the engine collector emits, namespaced by
# db_type: [metric.db.<engine>.<rule_id>] where <engine> is one of
# mysql | mariadb | oracle | postgresql | sqlite.
#
# Lookup order (see monitoring/db_metric_config.db_type_path + the
# ThresholdChecker fallback): the engine-specific section wins; if it is
# absent the generic [metric.db.<rule_id>] above is used.
#
# MySQL and MariaDB collect the same metrics but keep SEPARATE namespaces
# so each engine can be tuned or disabled independently. Disable any rule
# you don't want with `enabled = false`. Sentinel thresholds (99999 / large
# values at all levels) mark display-only / cumulative counters that should
# show in the UI but never raise an alert.
# ----------------------------------------------------------------

# ----------------------------------------------------------------
# MySQL  —  [metric.db.mysql.*]
# ----------------------------------------------------------------

[metric.db.mysql.active_connections]
critical    = 800
warning     = 400
info        = 200
operator    = >
unit        = count
window      = 3
enabled     = true
description = Active connections (MySQL)

[metric.db.mysql.total_connections]
critical    = 900
warning     = 600
info        = 300
operator    = >
unit        = count
window      = 3
enabled     = true
description = Total connections, active + idle (MySQL)

[metric.db.mysql.max_connections]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = count
window      = 1
enabled     = true
description = max_connections setting (MySQL; informational)

[metric.db.mysql.connection_usage_pct]
critical    = 90
warning     = 75
info        = 60
operator    = >
unit        = percent
window      = 3
enabled     = true
