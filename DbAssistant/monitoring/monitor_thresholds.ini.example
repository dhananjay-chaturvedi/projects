warning     = 50
info        = 20
operator    = >
unit        = count
window      = 3
enabled     = true
description = Threads currently running (MySQL)

[metric.db.mysql.uptime_sec]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = seconds
window      = 1
enabled     = true
description = Server uptime (MySQL; informational)

[metric.db.mysql.buffer_pool_used_mb]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = MB
window      = 1
enabled     = true
description = InnoDB buffer pool used (MySQL; informational)

[metric.db.mysql.buffer_pool_total_mb]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = MB
window      = 1
enabled     = true
description = InnoDB buffer pool total (MySQL; informational)

[metric.db.mysql.buffer_pool_usage_pct]
critical    = 95
warning     = 85
info        = 75
operator    = >
unit        = percent
window      = 3
enabled     = true
description = InnoDB buffer pool usage (MySQL)

[metric.db.mysql.bp_read_requests]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = count
window      = 1
enabled     = true
description = Buffer pool read requests (MySQL; used for hit ratio)

[metric.db.mysql.bp_disk_reads]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = count
window      = 1
enabled     = true
description = Buffer pool disk reads (MySQL; used for hit ratio)

[metric.db.mysql.cache_hit_ratio]
critical    = 0.5
warning     = 0.8
info        = 0.9
operator    = <
unit        = ratio
window      = 3
enabled     = true
description = Buffer pool hit ratio (MySQL)

[metric.db.mysql.query_cache_hits]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = count
window      = 1
enabled     = true
description = Query cache hits (MySQL; informational)

[metric.db.mysql.net_bytes_recv]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = bytes
window      = 1
enabled     = true
description = Bytes received from clients (MySQL; cumulative/informational)

[metric.db.mysql.net_bytes_sent]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = bytes
window      = 1
enabled     = true
description = Bytes sent to clients (MySQL; cumulative/informational)

[metric.db.mysql.io_read_mb]
critical    = 99999
warning     = 99999
info        = 99999
operator    = >
unit        = MB
window      = 1
enabled     = true
description = InnoDB data read (MySQL; cumulative/informational)

[metric.db.mysql.io_write_mb]
