# ================================================================
# CLOUD PROVIDER METRICS
# ================================================================
# Section name encodes the full canonical address:
#   [metric.<source>.<api>.<...path...>.<rule_id>]
#
# Examples:
#   [metric.aws.cloudwatch.RDS.FreeableMemory]
#   [metric.aws.pi.RDS.os_memory_free_avg]
#   [metric.azure.azuremonitor.DBforMySQL.flexibleServers.cpu_percent]
#   [metric.gcp.cloudmonitoring.cloudsql.database.cpu_utilization]
#
# Mandatory option for cloud sections:
#   metric_name  - exact API metric name passed to the cloud API.
#                  For AWS PI, GCP, etc., this is the verbatim string
#                  expected by GetResourceMetrics / list_time_series.
#
# Derived from the section path (no need to set unless overriding):
#   namespace          - AWS CloudWatch namespace (default "AWS/" + path[1])
#   service_type       - AWS PI service type (default path[1])
#   resource_provider  - Azure RP (default "Microsoft." + path[1] + "/" + path[2])
#   resource_type      - GCP monitored resource type (default path[1] + "_" + path[2])
# ================================================================


# ----------------------------------------------------------------
# AWS  —  CloudWatch (AWS/RDS namespace)
# ----------------------------------------------------------------

