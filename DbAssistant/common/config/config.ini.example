# ================================================================
# Database Management Tool - Configuration File (EXAMPLE)
# ================================================================
# Copy this file to ``<project-root>/config.ini`` and edit values
# to match your environment.
#
# SECURITY NOTE: The real config.ini may contain sensitive information.
# DO NOT commit your filled-in config.ini to version control.
# ================================================================

[paths]
# ---------------------------------------------------------------------------
# Storage layout
# ---------------------------------------------------------------------------
# Connection profiles + encryption keys are stored under a fixed internal
# layout at ``~/.dbassistant/`` (override with the DBASSISTANT_HOME env var
# for Docker / systemd / hermetic tests). Those paths are NOT configurable.
#
# Runtime artefacts (logs, daemon pid, metrics snapshot, alerts log) and
# per-session preferences (AI state, dashboard layout) default to
# ``<dbassistant home>/runtime`` and ``<dbassistant home>/session``.
# Override either by pointing at a fast local SSD or a system log dir.
runtime_dir =
session_dir =
# Optional override for the alerts log path (defaults to ``runtime/alerts.jsonl``).
alerts_log_file =
# Oracle Instant Client folder (required only for Oracle).
# Example: oracle_client_path = /path/to/instantclient_19_8
# Can also be overridden by the ORACLE_HOME environment variable.
oracle_client_path =

[database.ports]
# Default database ports
oracle = 1521
mysql = 3306
mariadb = 3306
postgresql = 5432
sqlite = 0
sqlserver = 1433
mongodb = 27017
documentdb = 27017

[database.connection]
# Connection timeout (seconds)
connection_timeout = 30.0
# Query execution timeout (seconds, 0 = no timeout)
query_timeout = 0
# Default autocommit mode
default_autocommit = true
# Connection retry attempts
max_connection_attempts = 8

[database.performance]
# Batch size for data transfer operations
transfer_batch_size = 1000
# Minimum rows for progress estimation
batch_min_rows = 10
# Maximum VARCHAR size
varchar_max_limit = 4000
# Minimum VARCHAR size
varchar_min_limit = 255
# VARCHAR buffer (additional bytes)
varchar_buffer = 50
# Use buffered cursors for MySQL/MariaDB
use_buffered_cursor = true
# Default number of rows returned by "sample table"
sample_default_rows = 5
# Hard cap on sample-table rows (guards against accidental full-table reads)
sample_max_rows = 1000
# Rows inserted per executemany batch during CSV import
import_chunk_size = 500

[api]
# REST API bind defaults used by `dbtool api`.
host = 127.0.0.1
port = 8000
# Comma-separated CORS origins. Leave blank to allow local web origins only.
# Set explicitly (for example, https://your-host) when exposing the API.
cors_origins =
# Maximum accepted request body size in bytes.
max_body_bytes = 10485760

[webui]
# Bind defaults used by `dbtool webui` (HTML/JS web UI + REST API + SPA).
host = 127.0.0.1
port = 8090

[tui]
# Bind defaults used by `dbtool tui --web` (Textual UI served in the browser).
host = 127.0.0.1
port = 8080

# NOTE: AI assistant settings ([ai], [ai.*]) moved to ai_query/config.ini.example
# (module-owned; edited via the AI tab settings button or `dbtool ai config`).

# NOTE: SSH ([ssh.connection]) and monitoring ([monitoring]) settings moved to
# the Monitoring module's own file: monitoring/monitor_config.ini (see
# monitoring/monitor_config.ini.example). This keeps the monitoring module
# independently shippable; the core tool no longer reads those sections.

[security]
# File permissions for encryption keys (octal)
key_file_permissions = 0o600
# File permissions for config files (octal)
config_file_permissions = 0o600

[encoding]
# List of encoding attempts (comma-separated)
encoding_attempts = utf-8,windows-1252,iso-8859-1,latin1

[project]
# Application version. Leave blank to read the top-level VERSION file.
version =
# Display timezone as a UTC offset, e.g. +5:30 (IST), -08:00 (PST), +00:00 (UTC).
# An IANA name (e.g. Asia/Kolkata) also works. Leave empty for the system default.
timezone =
# Enable debug logging
debug_mode = false
